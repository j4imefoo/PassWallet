<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <View
            android:layout_width="42dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_bottom_sheet_handle" />

        <TextView
            android:id="@+id/move_topic_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/move_to_new_topic"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/move_topic_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:text="@string/move_topic_subtitle"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/topic_suggestions_button_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/create_new_topic_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical|start"
            android:text="@string/create_new_topic"
            android:textAllCaps="false"
            android:textColor="@color/edit_action_text"
            app:backgroundTint="@color/edit_action_background"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_add_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/accent"
            app:strokeColor="@color/edit_action_stroke"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/new_topic_input_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_move_topic_input"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/new_topic_input_hint"
                android:textColor="@color/accent"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/new_topic_edit"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:importantForAutofill="no"
                android:hint="@string/new_topic_input_hint"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences|textNoSuggestions"
                android:padding="0dp"
                android:singleLine="true"
                android:textColor="@color/edit_action_text"
                android:textColorHint="?android:attr/textColorSecondary"
                android:textCursorDrawable="@drawable/bg_text_cursor_accent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/new_topic_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="end"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancel_button"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAllCaps="false"
                android:textColor="?android:attr/textColorSecondary"
                android:text="@android:string/cancel" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/ok_button"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@android:string/ok"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/accent"
                app:cornerRadius="18dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
