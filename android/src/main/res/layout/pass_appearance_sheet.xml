<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="12dp"
    android:paddingEnd="20dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:text="@string/pass_appearance_title"
        android:textColor="?android:textColorPrimary"
        android:textSize="20sp"
        tools:text="Personalizar pase" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="@string/pass_appearance_subtitle"
        android:textColor="?android:textColorSecondary"
        android:textSize="14sp"
        tools:text="Ajusta el tipo, color e icono del pase." />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/selectCategory"
        style="@style/PassWallet.AppearanceSheetAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_category_dialog_title"
        app:icon="@drawable/ic_ticket_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/selectColor"
        style="@style/PassWallet.AppearanceSheetAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/change_color_dialog_title"
        app:icon="@drawable/ic_palette_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/selectIcon"
        style="@style/PassWallet.AppearanceSheetAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_icon"
        app:icon="@drawable/ic_image_photo_camera" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/selectLogo"
        style="@style/PassWallet.AppearanceSheetAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/select_logo"
        app:icon="@drawable/ic_image_photo_camera" />

</LinearLayout>
