<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_destructive_dialog"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="24dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <ImageView
        android:id="@+id/confirmationIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_destructive_icon"
        android:contentDescription="@null"
        android:padding="10dp"
        android:src="@drawable/ic_action_delete"
        app:tint="@color/danger_on_container" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/confirmationTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="?android:textColorPrimary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/confirmationMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:lineSpacingExtra="2dp"
        android:textColor="?android:textColorSecondary"
        android:textSize="15sp" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/sourceDeleteCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:buttonTint="@color/secondary"
        android:fontFamily="sans-serif"
        android:paddingStart="0dp"
        android:textColor="?android:textColorPrimary"
        android:textSize="15sp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmationCancel"
            style="@style/PassWallet.DialogTextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@android:string/cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/confirmationConfirm"
            style="@style/PassWallet.DialogDangerButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>
