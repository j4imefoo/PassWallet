<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sortOrderRowCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/edit_action_background"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/edit_action_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/sortOrderLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/edit_action_text"
            android:textSize="16sp"
            tools:text="Fecha ascendente" />

        <ImageView
            android:id="@+id/sortOrderSelectedCheck"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/selected"
            android:src="@drawable/ic_check_24"
            android:visibility="gone"
            app:tint="@color/edit_action_text"
            tools:visibility="visible" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
